# sync-observer — 로컬 hermes 모니터.
# 모든 값은 선택이다. 기본값만으로 동작하므로 보통 .env 없이도 실행된다.

# ── 컬렉터 (server/src/collector) ──────────────────────────────────────────
# 항상 127.0.0.1 에만 바인딩된다(override 불가). 포트만 바꿀 수 있다.
# SYNCSPACE_COLLECTOR_PORT=8787
# SYNCSPACE_DB_PATH=./.syncspace/collector.db
# SYNCSPACE_RULES_FILE=./.syncspace/rules.json

# 브라우저 UI에 허용할 origin (기본: localhost/127.0.0.1 의 5173·3000)
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 프론트(빌드 타임, 선택) ───────────────────────────────────────────────
# 컬렉터 주소를 바꿨을 때만. 기본 http://127.0.0.1:8787
# VITE_COLLECTOR_URL=http://127.0.0.1:8787

# ── hermes 플러그인 env 는 이 파일이 아니라 hermes 실행 셸에 설정한다 ──────
#   SYNCSPACE_COLLECTOR_URL / SYNCSPACE_RULES_FILE / SYNCSPACE_AGENT_DISAMBIGUATOR
#   자세한 내용은 hermes-plugin/README.md 참고.
