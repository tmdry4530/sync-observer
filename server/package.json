    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@y/websocket-server": "0.1.1",
    "pg": "^8.21.0",
    "ws": "^8.21.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "embedded-postgres": "18.4.0-beta.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "22.x"
  }
}
