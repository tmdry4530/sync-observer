{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/collector/main.js",
  "scripts": {
    "dev:collector": "tsx watch src/collector/main.ts",
    "start:collector": "node dist/collector/main.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
