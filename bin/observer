#!/usr/bin/env bash
# observer — sync-observer 로컬 모니터 런처 (데몬).
#   observer [start]   컬렉터 + UI 백그라운드 기동 후 브라우저 열기
#   observer stop      모두 중지
#   observer restart   재시작
#   observer status    상태/포트 확인
#   observer logs      로그 tail
set -euo pipefail

DIR="${SYNC_OBSERVER_DIR:-$HOME/.sync-observer}"
RUN="$DIR/.run"
UI_PORT="${OBSERVER_UI_PORT:-5173}"
COLLECTOR_PORT="${SYNCSPACE_COLLECTOR_PORT:-8787}"
URL="http://127.0.0.1:${UI_PORT}/monitor"

c_info() { printf '\033[1;36m[observer]\033[0m %s\n' "$*"; }
c_warn() { printf '\033[1;33m[observer]\033[0m %s\n' "$*" >&2; }

port_up()   { curl -s -o /dev/null -m 1 "http://127.0.0.1:$1" 2>/dev/null; }
pid_alive() { [ -f "$1" ] && kill -0 "$(cat "$1")" 2>/dev/null; }

# pid + 모든 자손 프로세스 종료 (pnpm→node 트리까지). macOS/Linux 공통(pgrep -P).
kill_tree() {
  local pid=$1 child
  for child in $(pgrep -P "$pid" 2>/dev/null || true); do kill_tree "$child"; done
  kill "$pid" 2>/dev/null || true
}

open_browser() {
  [ -n "${OBSERVER_NO_OPEN:-}" ] && { c_info "브라우저 자동 열기 생략: $URL"; return; }
  if command -v open >/dev/null 2>&1; then open "$URL" >/dev/null 2>&1 || true
  elif command -v xdg-open >/dev/null 2>&1; then xdg-open "$URL" >/dev/null 2>&1 || true
  else c_info "브라우저에서 열기: $URL"; fi
}

ensure_installed() {
  [ -d "$DIR/.git" ] || { c_warn "설치 디렉터리 없음: $DIR"; c_warn "먼저 설치: curl -fsSL https://raw.githubusercontent.com/tmdry4530/sync-observer/main/install.sh | bash"; exit 1; }
}

start_one() { # name  pnpm-args...
  local name=$1; shift
  local pidf="$RUN/$name.pid" logf="$RUN/$name.log"
  if pid_alive "$pidf"; then c_info "$name 이미 실행 중 (pid $(cat "$pidf"))"; return; fi
  ( cd "$DIR" && nohup "$@" >"$logf" 2>&1 & echo $! >"$pidf" )
  c_info "$name 시작 (pid $(cat "$pidf"))"
}

cmd_start() {
  ensure_installed
  mkdir -p "$RUN"
  # 'serve' (non-watch): the collector writes its sqlite db into the project
  # tree, which a file-watcher would treat as a change and restart-churn on.
  start_one collector pnpm --filter server serve:collector
  start_one ui        pnpm dev:frontend
  printf '\033[1;36m[observer]\033[0m UI 기동 대기'
  local i
  for i in $(seq 1 90); do port_up "$UI_PORT" && break; printf '.'; sleep 1; done
  printf '\n'
  if port_up "$UI_PORT"; then
    c_info "준비 완료 → $URL"
    port_up "$COLLECTOR_PORT" || c_warn "컬렉터(:$COLLECTOR_PORT) 응답 없음 — 'observer logs' 확인"
    open_browser
  else
    c_warn "UI(:$UI_PORT)가 시간 내 기동 실패 — 'observer logs' 확인"
    exit 1
  fi
}

cmd_stop() {
  local name pidf stopped=0
  for name in ui collector; do
    pidf="$RUN/$name.pid"
    if pid_alive "$pidf"; then kill_tree "$(cat "$pidf")"; c_info "$name 중지"; stopped=1; fi
    rm -f "$pidf"
  done
  [ "$stopped" = 0 ] && c_info "실행 중인 프로세스 없음"
}

cmd_status() {
  local name pidf
  for name in collector ui; do
    pidf="$RUN/$name.pid"
    if pid_alive "$pidf"; then c_info "$name: 실행 중 (pid $(cat "$pidf"))"; else c_info "$name: 중지됨"; fi
  done
  port_up "$COLLECTOR_PORT" && c_info "컬렉터 :$COLLECTOR_PORT 응답 OK" || c_warn "컬렉터 :$COLLECTOR_PORT 무응답"
  port_up "$UI_PORT"        && c_info "UI :$UI_PORT 응답 OK ($URL)" || c_warn "UI :$UI_PORT 무응답"
}

cmd_logs() { tail -n 40 -F "$RUN/collector.log" "$RUN/ui.log" 2>/dev/null; }

case "${1:-start}" in
  start|"") cmd_start ;;
  stop)     cmd_stop ;;
  restart)  cmd_stop; sleep 1; cmd_start ;;
  status)   cmd_status ;;
  logs)     cmd_logs ;;
  -h|--help|help) sed -n '2,8p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) echo "usage: observer [start|stop|restart|status|logs]" >&2; exit 1 ;;
esac
