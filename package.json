{
  "name": "syncspace",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "bash scripts/dev-all.sh",
    "dev:frontend": "vite --host 127.0.0.1 --port 5173",
    "dev:collector": "pnpm --filter server dev:collector",
    "build": "tsc -p tsconfig.json && vite build && pnpm -r build",
    "preview": "vite preview",
    "lint": "tsc -p tsconfig.json --noEmit && pnpm -r lint",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm -r typecheck",
    "verify:frontend": "tsc -p tsconfig.json --noEmit && vite build",
    "verify:backend": "pnpm --filter server lint && pnpm --filter server typecheck && pnpm --filter server build",
    "verify:all": "pnpm typecheck && pnpm verify:frontend && pnpm verify:backend",
    "test": "pnpm --filter server test",
    "test:server": "pnpm --filter server test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.7",
    "@tiptap/extension-collaboration": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.17.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": "22.x"
  }
}
